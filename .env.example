# ── Shioaji credentials ──────────────────────────────────────────────
# Required by `shioaji server start` (the CLI reads .env from this dir).
# Create your API key / secret key at:
#   https://www.sinotrade.com.tw/newweb/PythonAPIKey/
# Copy this file to `.env` and fill in your keys. NEVER commit `.env`.
SJ_API_KEY=your_api_key_here
SJ_SEC_KEY=your_secret_key_here

# The server runs in SIMULATION mode by default (paper trading).
# Only set this to true when you are ready for real trading — it also
# requires your CA certificate (SJ_CA_PATH / SJ_CA_PASSWD).
# SJ_PRODUCTION=true

# ── Frontend (optional) ──────────────────────────────────────────────
# Override REST/SSE base URL for a remote shioaji server.
# Leave unset when using the dev proxy or when deployed under /apps/<name>/.
# VITE_API_BASE=http://my-shioaji-server.local:8080

# Build-time public base path when deploying as a shioaji custom app.
# VITE_BASE=/apps/shioaji-pro-app/
